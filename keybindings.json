[
  // ════════════════════════════════════════════════════════════════════════════════
  // NAVIGATION — Editor & History
  // ════════════════════════════════════════════════════════════════════════════════
  { "key": "ctrl+-", "command": "workbench.action.navigateBack" },
  { "key": "ctrl+shift+-", "command": "workbench.action.navigateForward" },

  // ════════════════════════════════════════════════════════════════════════════════
  // QUICK OPEN & SEARCH
  // ════════════════════════════════════════════════════════════════════════════════
  { "key": "cmd+p", "command": "workbench.action.quickOpen" },

  // ════════════════════════════════════════════════════════════════════════════════
  // TABS — Cycle, Jump, & Management
  // ════════════════════════════════════════════════════════════════════════════════

  // ── Cycle between tabs ──
  { "key": "ctrl+tab", "command": "workbench.action.nextEditor" },
  { "key": "ctrl+shift+tab", "command": "workbench.action.previousEditor" },
  {
    "key": "ctrl+tab",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus",
  },
  {
    "key": "ctrl+shift+tab",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus",
  },

  // ── Jump to tab by index (cmd+1 through cmd+9) ──
  { "key": "cmd+1", "command": "workbench.action.openEditorAtIndex1" },
  { "key": "cmd+2", "command": "workbench.action.openEditorAtIndex2" },
  { "key": "cmd+3", "command": "workbench.action.openEditorAtIndex3" },
  { "key": "cmd+4", "command": "workbench.action.openEditorAtIndex4" },
  { "key": "cmd+5", "command": "workbench.action.openEditorAtIndex5" },
  { "key": "cmd+6", "command": "workbench.action.openEditorAtIndex6" },
  { "key": "cmd+7", "command": "workbench.action.openEditorAtIndex7" },
  { "key": "cmd+8", "command": "workbench.action.openEditorAtIndex8" },
  { "key": "cmd+9", "command": "workbench.action.openEditorAtIndex9" },

  // ── Tab management: pin, close groups ──
  {
    "key": "cmd+alt+p",
    "command": "workbench.action.pinEditor",
    "when": "!activeEditorIsPinned",
  },
  {
    "key": "cmd+alt+p",
    "command": "workbench.action.unpinEditor",
    "when": "activeEditorIsPinned",
  },
  { "key": "cmd+alt+e", "command": "workbench.action.closeOtherEditors" },
  { "key": "cmd+alt+l", "command": "workbench.action.closeEditorsToTheLeft" },
  { "key": "cmd+alt+r", "command": "workbench.action.closeEditorsToTheRight" },

  // ════════════════════════════════════════════════════════════════════════════════
  // SPLITS — Create & Navigate
  // ════════════════════════════════════════════════════════════════════════════════

  // ── Create splits ──
  { "key": "cmd+shift+d", "command": "workbench.action.splitEditorDown" },

  // ── Focus split by group (ctrl+1 through ctrl+4) ──
  {
    "key": "ctrl+shift+1",
    "command": "workbench.action.focusFirstEditorGroup",
  },
  {
    "key": "ctrl+shift+2",
    "command": "workbench.action.focusSecondEditorGroup",
  },
  {
    "key": "ctrl+shift+3",
    "command": "workbench.action.focusThirdEditorGroup",
  },
  {
    "key": "ctrl+shift+4",
    "command": "workbench.action.focusFourthEditorGroup",
  },

  // ── Move editors within/across splits ──
  {
    "key": "cmd+alt+left",
    "command": "workbench.action.moveEditorLeftInGroup",
  },
  {
    "key": "cmd+alt+right",
    "command": "workbench.action.moveEditorRightInGroup",
  },
  { "key": "ctrl+w left", "command": "workbench.action.moveEditorToLeftGroup" },
  {
    "key": "ctrl+w right",
    "command": "workbench.action.moveEditorToRightGroup",
  },

  // ════════════════════════════════════════════════════════════════════════════════
  // TERMINAL
  // ════════════════════════════════════════════════════════════════════════════════
  { "key": "ctrl+`", "command": "workbench.action.terminal.toggleTerminal" },

  // ════════════════════════════════════════════════════════════════════════════════
  // FOLDING — Cursor-safe, integrates with vim keybinds (Ctrl+[ and Ctrl+] override vim)
  // ════════════════════════════════════════════════════════════════════════════════

  // ── Granular: toggle at cursor position ──
  {
    "key": "ctrl+shift+[",
    "command": "editor.toggleFold",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "ctrl+shift+]",
    "command": "editor.toggleFold",
    "when": "editorTextFocus && foldingEnabled",
  },

  // ── Single fold/unfold (overrides vim) ──
  {
    "key": "ctrl+[",
    "command": "editor.fold",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "ctrl+]",
    "command": "editor.unfold",
    "when": "editorTextFocus && foldingEnabled",
  },

  // ── Whole-file folds; ctrl+0 is the universal revert ──
  {
    "key": "ctrl+shift+\\",
    "command": "editor.foldAllExcept",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "ctrl+shift+enter",
    "command": "editor.foldAll",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "ctrl+1",
    "command": "editor.foldLevel1",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "ctrl+2",
    "command": "editor.foldLevel2",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "ctrl+3",
    "command": "editor.foldLevel3",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "ctrl+4",
    "command": "editor.foldLevel4",
    "when": "editorTextFocus && foldingEnabled",
  },

  {
    "key": "ctrl+0",
    "command": "editor.unfoldAll",
    "when": "editorTextFocus && foldingEnabled",
  },

  {
    "key": "ctrl+\\",
    "command": "editor.unfoldAll",
    "when": "editorTextFocus && foldingEnabled",
  }, // ── Marker regions: fold + its own revert ──
  {
    "key": "ctrl+shift+8",
    "command": "editor.foldAllMarkerRegions",
    "when": "editorTextFocus && foldingEnabled",
  },
  {
    "key": "ctrl+shift+9",
    "command": "editor.unfoldAllMarkerRegions",
    "when": "editorTextFocus && foldingEnabled",
  },

  // ════════════════════════════════════════════════════════════════════════════════
  // EDITING
  // ════════════════════════════════════════════════════════════════════════════════
  {
    "key": "cmd+y",
    "command": "redo",
    "when": "editorTextFocus && !editorReadonly",
  },
  {
    "key": "shift+cmd+z",
    "command": "-redo",
    "when": "editorTextFocus && !editorReadonly",
  },

  // ════════════════════════════════════════════════════════════════════════════════
  // GIT
  // ════════════════════════════════════════════════════════════════════════════════
  { "key": "cmd+shift+g", "command": "workbench.view.scm" },
  {
    "key": "cmd+shift+h",
    "command": "git.openChange",
    "when": "editorTextFocus",
  },

  // ════════════════════════════════════════════════════════════════════════════════
  // UI TOGGLES & VISIBILITY
  // ════════════════════════════════════════════════════════════════════════════════
  { "key": "cmd+\\", "command": "workbench.action.toggleSidebarVisibility" },
  { "key": "cmd+b", "command": "workbench.action.toggleActivityBarVisibility" },
  { "key": "cmd+m", "command": "editor.action.toggleMinimap" },
  { "key": "cmd+shift+t", "command": "workbench.action.selectTheme" },
  { "key": "cmd+shift+i", "command": "workbench.action.selectIconTheme" },
  {
    "key": "cmd+shift+r",
    "command": "workbench.files.action.showActiveFileInExplorer",
  },

  // ════════════════════════════════════════════════════════════════════════════════
  // ZOOM & DIAGNOSTICS
  // ════════════════════════════════════════════════════════════════════════════════
  { "key": "cmd+;", "command": "workbench.action.decreaseViewSize" },
  { "key": "cmd+'", "command": "workbench.action.increaseViewSize" },
  { "key": "cmd+0", "command": "workbench.action.zoomReset" },

  // ── Toggle TypeScript/JavaScript diagnostics ──
  {
    "key": "cmd+shift+alt+e",
    "command": "settings.cycle",
    "args": {
      "id": "toggle-diagnostics",
      "values": [
        {
          "typescript.validate.enable": true,
          "javascript.validate.enable": true,
          "editor.renderValidationDecorations": "on",
        },
        {
          "typescript.validate.enable": false,
          "javascript.validate.enable": false,
          "editor.renderValidationDecorations": "off",
        },
      ],
    },
  },
]

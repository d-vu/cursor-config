    "breadcrumb.foreground": "#d8d4eafd",
    "activityBar.border": "#22212c",
    "sideBar.background": "#262833",
    "sideBar.foreground": "#b2b2d0",
    "sideBarSectionHeader.background": "#22212c",
    "sideBarSectionHeader.foreground": "#92a2d4",
    "sideBarSectionHeader.border": "#92a2d4",
    "statusBar.background": "#22212c",
    "statusBar.foreground": "#6272a4",
    "statusBar.noFolderBackground": "#22212c",
    "statusBar.debuggingBackground": "#22212c",
    "statusBar.debuggingForeground": "#6272a4",
    "editor.selectionBackground": "#9580ff40",
    "editor.selectionHighlightBackground": "#9580ff25",
    "editor.foldBackground": "#282a3610",
    "editor.wordHighlightBackground": "#9580ff18",
    "editor.wordHighlightBorder": "#9580ff60",
    "editor.wordHighlightStrongBackground": "#9580ff30",
    "editor.wordHighlightStrongBorder": "#9580ff90",
    "editorLineNumber.foreground": "#44475a",
    "editorLineNumber.activeForeground": "#9580ff",

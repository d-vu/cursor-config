  // ─────────────────────────────────────────────────────────
  // FORMATTING
  // ─────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "prettier.bracketSameLine": true,

  // ─────────────────────────────────────────────────────────
  // TYPESCRIPT / JAVASCRIPT
  // ─────────────────────────────────────────────────────────
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": true,

  // ─────────────────────────────────────────────────────────
  // TABS
  // ─────────────────────────────────────────────────────────
  "workbench.editor.wrapTabs": true,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.decorations.badges": true,
  "workbench.editor.decorations.colors": true,
  "workbench.editor.tabActionCloseVisibility": false,
  "workbench.editor.labelFormat": "short",
  "workbench.editor.splitSizing": "distribute",

  // ─────────────────────────────────────────────────────────
  // EXPLORER & FILE TREE
  // ─────────────────────────────────────────────────────────
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "explorer.autoReveal": false,
  "explorer.openEditors.visible": 0,
  "explorer.decorations.badges": true,
  "explorer.decorations.colors": true,
  "explorer.sortOrder": "type",
  "workbench.tree.renderIndentGuides": "always",
  "workbench.tree.indent": 12,

  // ─────────────────────────────────────────────────────────
  // FILE NESTING
  // ─────────────────────────────────────────────────────────
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.d.ts, ${capture}.test.ts",
    "*.tsx": "${capture}.test.tsx, ${capture}.stories.tsx",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, .npmrc",
    "tsconfig.json": "tsconfig.*.json",
    ".env": ".env.*, .envrc",
    "*.css": "${capture}.module.css",
  },

  // ─────────────────────────────────────────────────────────
  // BREADCRUMBS
  // ─────────────────────────────────────────────────────────
  "breadcrumbs.showFunctions": true,
  "breadcrumbs.showVariables": false,
  "breadcrumbs.showProperties": false,
  "breadcrumbs.symbolPath": "off",

  // ─────────────────────────────────────────────────────────
  // SEARCH
  // ─────────────────────────────────────────────────────────
  "search.showLineNumbers": true,
  "search.smartCase": true,
  "search.seedWithNearestWord": true,

  // ─────────────────────────────────────────────────────────
  // TERMINAL
  // ─────────────────────────────────────────────────────────
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorWidth": 1,
  "terminal.integrated.mouseWheelZoom": true,
  "terminal.integrated.defaultLocation": "editor",

  // ─────────────────────────────────────────────────────────
  // WORKBENCH & WINDOW
  // ─────────────────────────────────────────────────────────
  "workbench.sideBar.location": "right",
  "workbench.list.smoothScrolling": true,
  "workbench.enableExperiments": false,
  "workbench.view.showQuietly": {
    "workbench.panel.output": false,
  },
  "workbench.agentsWindowButton.enabled": false,
  "window.titleBarStyle": "custom",
  "window.title": "${activeFolderMedium} - (${activeEditorShort})",
  "window.zoomPerWindow": false,
  "window.zoomLevel": 1,
  "window.autoDetectColorScheme": false,

  // ─────────────────────────────────────────────────────────
  // ZEN MODE
  // ─────────────────────────────────────────────────────────
  "zenMode.centerLayout": true,
  "zenMode.fullScreen": false,
  "zenMode.showTabs": "none",
  "zenMode.hideActivityBar": false,
  "zenMode.hideStatusBar": false,
  "zenMode.hideLineNumbers": false,

  // ─────────────────────────────────────────────────────────
  // SCREENCAST MODE
  // ─────────────────────────────────────────────────────────
  "screencastMode.verticalOffset": 2,
  "screencastMode.fontSize": 20,
  "screencastMode.mouseIndicatorColor": "#00000000", // fully transparent
  "screencastMode.keyboardOverlayTimeout": 5000,

  // ─────────────────────────────────────────────────────────
  // ACCESSIBILITY
  // ─────────────────────────────────────────────────────────
  "accessibility.dimUnfocused.enabled": false,
  "accessibility.dimUnfocused.opacity": 0.85,
  "accessibility.accessibleView.closeOnKeyPress": false,

  // ─────────────────────────────────────────────────────────
  // VIM
  //
  // Status bar mode colors ([bg, fg]):
  //   normal   → chrome dark + muted blue   (inactive feel)
  //   insert   → dark green + bright green  (action mode)
  //   visual   → dark amber + orange        (selection)
  //   v-line   → dark amber + orange        (matches visual)
  //   v-block  → dark red + coral           (most aggressive selection)
  //   replace  → dark magenta + pink        (destructive overwrite)
  //   search   → dark blue + steel blue     (lookup mode)
  // ─────────────────────────────────────────────────────────
  "vim.disableExtension": false,
  "vim.startInInsertMode": false,
  "vim.handleKeys": {
    "<D-S-[>": false,
    "<D-d>": false,
    "<D-S-]>": false,
    "<D-c>": false,
    "<C-c>": false,
  },
  "vim.statusBarColorControl": true,
  "vim.statusBarColors.normal": ["#22212c", "#6272a4"],
  "vim.statusBarColors.insert": ["#32634a", "#8aff80"],
  "vim.statusBarColors.visual": ["#2d2415", "#ffca80"],
  "vim.statusBarColors.visualline": ["#2d2415", "#ffca80"],
  "vim.statusBarColors.visualblock": ["#2d1e14", "#ff9580"],
  "vim.statusBarColors.replace": ["#2d1522", "#ff92df"],
  "vim.statusBarColors.searchinprogressmode": ["#15202d", "#92a2d4"],
  "vim.cursorStylePerMode.normal": "underline",
  "vim.showcmd": true,
  "vim.mouseSelectionGoesIntoVisualMode": true,
  "vim.foldfix": true,
  "vim.hlsearch": true,

  // ─────────────────────────────────────────────────────────
  // CURSOR AI
  // ─────────────────────────────────────────────────────────
  "cursor.cpp.disabledLanguages": [
    "markdown",
    "plaintext",
    "typescriptreact",
    "typescript",
  ],
  "claudeCode.preferredLocation": "panel",

  // ─────────────────────────────────────────────────────────
  // DATETIME (status bar)
  // ─────────────────────────────────────────────────────────
  "dateTime.showAMPM": true,
  "dateTime.showSeconds": true,
  "dateTime.showDayOfMonth": true,
  "dateTime.showDayOfWeek": true,
  "dateTime.showMonth": true,
  "dateTime.use24HourClock": false,
  "dateTime.padDays": true,
  "dateTime.padHours": false,

  // ─────────────────────────────────────────────────────────
  // BACKGROUND EXTENSION
  // Enabled flag is on, but image config is commented out
  // (extension had compatibility issues with recent Cursor versions)
  // ─────────────────────────────────────────────────────────
  "background.enabled": true,
  // "background.editor": {
  //   "useFront": true,
  //   "style": {
  //     "background-position": "0px 0px",
  //     "background-size": "cover",
  //     "opacity": 0.025,
  //   },
  //   "images": [
  //     "data:image/svg+xml;base64,",
  //   ],
  //   "interval": 0,
  //   "random": false,
  // },
}

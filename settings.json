{
  // ═════════════════════════════════════════════════════════
  // MODE TOGGLE — flip comments to switch
  // ═════════════════════════════════════════════════════════

  // ── CODING MODE (quiet: no lint, no error lines) ──
  "typescript.validate.enable": false,
  "javascript.validate.enable": false,
  "editor.renderValidationDecorations": "off",
  "errorLens.enabled": false,

  // ── REVIEW MODE (full diagnostics) ──
  // "typescript.validate.enable": true,
  // "javascript.validate.enable": true,
  // "editor.renderValidationDecorations": "on",
  // "errorLens.enabled": true,

  // ═════════════════════════════════════════════════════════
  // PALETTE REFERENCE (single source of truth)
  //
  // Syntax colors:
  //   Functions / methods / classes    #62e884  green
  //   Variable declarations            #bd93f9  purple
  //   Variable usages                  #7fdff4  cyan
  //   Mutable vars (non-TS fallback)   #78d7ed  cyan (slightly deeper)
  //   Properties                       #efefef  off-white
  //   Types / interfaces / enums       #9bc4e2  powder blue, bold
  //   Comments                         #9988bb  muted purple
  //   Strings                          #ddd683  muted yellow
  //   Numbers                          #dcdf53  yellow-green
  //   Logical/comparison operators     #f8c5ff  pale pink, bold
  //   Built-in vars (this, super)      #e668af  pink
  //   JSX/HTML attribute names         #c9b6f5  lavender
  //   React components / JSX tags      #ff9580  coral
  //
  // UI chrome:
  //   Editor bg                        #282a36  (Dracula Soft default)
  //   Chrome bg (dark)                 #22212c  (title bar inactive, sidebar headers, hovers)
  //   Sidebar bg                       #262833
  //   Borders / muted                  #44475a, #6272a4
  //   Foreground (main)                #f8f8f2
  //   Foreground (muted)               #b2b2d0, #92a2d4
  //   Accent purple                    #9580ff  (selections, word highlights, line nums, minimap)
  //   Status bar                       #32634a bg / #8aff80 fg  (green — matches vim insert)
  //   Diagnostics                      #ff9580 error, #ffca80 warn, #92a2d4 info, #8aff80 hint
  // ═════════════════════════════════════════════════════════

  // ─────────────────────────────────────────────────────────
  // THEME & ICONS
  // ─────────────────────────────────────────────────────────
  "workbench.colorTheme": "Dracula Theme Soft",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.iconTheme": "vscode-great-icons",

  // ─────────────────────────────────────────────────────────
  // SEMANTIC TOKEN COLORS (TypeScript — wins over TextMate)
  // ─────────────────────────────────────────────────────────
  "editor.semanticTokenColorCustomizations": {
    "[Dracula Theme Soft]": {
      "rules": {
        // Functions, methods, built-in classes → green
        "function": { "foreground": "#62e884" },
        "method": { "foreground": "#62e884" },
        "function.defaultLibrary": { "foreground": "#62e884" },
        "method.defaultLibrary": { "foreground": "#62e884" },
        "class.defaultLibrary": { "foreground": "#62e884", "italic": false },

        // Variable declarations (const/let/var) → purple
        "variable.declaration": { "foreground": "#bd93f9" },
        "variable.declaration.local": { "foreground": "#bd93f9" },
        "variable.declaration.readonly": { "foreground": "#bd93f9" },
        "variable.declaration.readonly.local": { "foreground": "#bd93f9" },

        // Variable usages (references) → cyan
        "variable": { "foreground": "#7fdff4" },
        "variable.readonly": { "foreground": "#7fdff4" },
        "variable.local": { "foreground": "#7fdff4" },
        "variable.readonly.local": { "foreground": "#7fdff4" },

        // Properties (defs + access) → off-white
        "property.declaration": { "foreground": "#efefef" },
        "property.declaration.readonly": { "foreground": "#efefef" },
        "property": { "foreground": "#efefef" },
        "property.readonly": { "foreground": "#efefef" },
        "property.defaultLibrary": { "foreground": "#efefef" },
        "property.defaultLibrary.readonly": { "foreground": "#efefef" },

        // Types, interfaces, enums → powder blue, bold
        "type": { "foreground": "#9bc4e2", "bold": true },
        "typeParameter": { "foreground": "#9bc4e2", "bold": true },
        "enum": { "foreground": "#9bc4e2", "bold": true },
        "interface": { "foreground": "#9bc4e2", "italic": false, "bold": true },
        "interface.defaultLibrary": {
          "foreground": "#9bc4e2",
          "bold": true,
          "italic": false,
        },
      },
    },
  },

  // ─────────────────────────────────────────────────────────
  // TEXTMATE TOKEN COLORS (fallback when semantic doesn't apply)
  // ─────────────────────────────────────────────────────────
  "editor.tokenColorCustomizations": {
    "[Dracula Theme Soft]": {
      "textMateRules": [
        // Comments → muted purple
        {
          "scope": ["comment", "punctuation.definition.comment"],
          "settings": { "foreground": "#9988bb", "fontStyle": "" },
        },

        // Class names → green, bold
        {
          "scope": ["entity.name.type.class"],
          "settings": { "foreground": "#62e884", "fontStyle": "bold" },
        },

        // Strip italics from types / params / JSX attrs (no color change)
        {
          "scope": [
            "variable.parameter",
            "entity.name.type",
            "support.type.primitive",
            "support.type.builtin",
            "meta.type.annotation.ts",
            "support.class.component.tsx",
            "entity.other.attribute-name.tsx",
            "variable.language.this",
          ],
          "settings": { "fontStyle": "" },
        },

        // Strings → muted yellow
        {
          "scope": "string",
          "settings": { "foreground": "#ddd683" },
        },

        // Primitive type keywords (string, number, boolean) → powder blue
        // Matches semantic type color for consistency in non-TS files
        {
          "scope": ["support.type.primitive", "support.type.builtin"],
          "settings": { "foreground": "#9bc4e2" },
        },

        // Logical / comparison operators → pale pink, bold
        {
          "scope": [
            "keyword.operator.logical",
            "keyword.operator.comparison",
            "keyword.operator.relational",
          ],
          "settings": { "foreground": "#f8c5ff", "fontStyle": "bold" },
        },

        // Numbers → yellow-green
        {
          "scope": ["constant.numeric.decimal", "constant.numeric"],
          "settings": { "foreground": "#dcdf53" },
        },

        // JSONC property names → off-white (matches semantic property color)
        {
          "scope": [
            "support.type.property-name.json.comments",
            "punctuation.support.type.property-name.begin.json.comments",
            "punctuation.support.type.property-name.end.json.comments",
          ],
          "settings": { "foreground": "#efefef" },
        },

        // Mutable variables (non-TS fallback) → cyan
        {
          "scope": [
            "variable.other.readwrite",
            "variable.other.constant.object",
          ],
          "settings": { "foreground": "#78d7ed" },
        },

        // Built-in vars (this, super, etc.) → pink
        {
          "scope": ["support.variable", "variable.language.this.ts"],
          "settings": { "foreground": "#e668af" },
        },

        // Object properties (non-TS fallback) → off-white
        {
          "scope": [
            "variable.other.property",
            "support.constant.property",
            "support.variable.property",
          ],
          "settings": { "foreground": "#efefef" },
        },

        // JSX/HTML attribute names → lavender
        {
          "scope": "entity.other.attribute-name",
          "settings": { "foreground": "#c9b6f5" },
        },

        // Functions, built-in classes → green
        {
          "scope": [
            "support.function",
            "entity.name.function",
            "support.class.builtin",
          ],
          "settings": { "foreground": "#62e884" },
        },

        // React components, JSX tags → coral
        {
          "scope": ["support.class.component"],
          "settings": { "foreground": "#ff9580" },
        },
      ],
    },
  },

  // ─────────────────────────────────────────────────────────
  // WORKBENCH COLOR CUSTOMIZATIONS (UI chrome)
  // See palette reference at top of file
  // ─────────────────────────────────────────────────────────
  "workbench.colorCustomizations": {
    // Current line
    "editor.lineHighlightBorder": "#00000000",
    "editor.lineHighlightBackground": "#9580ff08",

    // Title bar
    "titleBar.activeBackground": "#282a36",
    "titleBar.activeForeground": "#f8f8f2",
    "titleBar.inactiveBackground": "#22212c",
    "titleBar.inactiveForeground": "#6272a4",
    "titleBar.border": "#44475a",

    // Breadcrumbs
    "breadcrumb.foreground": "#d8d4eafd",

    // Sidebar & activity bar
    "activityBar.border": "#22212c",
    "sideBar.background": "#262833",
    "sideBar.foreground": "#b2b2d0",
    "sideBarSectionHeader.background": "#22212c",
    "sideBarSectionHeader.foreground": "#92a2d4",
    "sideBarSectionHeader.border": "#92a2d4",

    // Status bar → green (matches vim insert mode)
    "statusBar.background": "#32634a",
    "statusBar.foreground": "#8aff80",
    "statusBar.noFolderBackground": "#32634a",
    "statusBar.debuggingBackground": "#32634a",
    "statusBar.debuggingForeground": "#8aff80",

    // Selections & word highlights → accent purple
    "editor.selectionBackground": "#9580ff40",
    "editor.selectionHighlightBackground": "#9580ff25",
    "editor.foldBackground": "#282a3610",
    "editor.wordHighlightBackground": "#9580ff18",
    "editor.wordHighlightBorder": "#9580ff60",
    "editor.wordHighlightStrongBackground": "#9580ff30",
    "editor.wordHighlightStrongBorder": "#9580ff90",

    // Line numbers & inlay hints
    "editorLineNumber.foreground": "#44475a",
    "editorLineNumber.activeForeground": "#9580ff",
    "editorInlayHint.foreground": "#6b5f8a",
    "editorInlayHint.background": "#00000000",

    // Hover widget
    "editorHoverWidget.background": "#22212c",
    "editorHoverWidget.foreground": "#f8f8f2",
    "editorHoverWidget.border": "#9580ff40",
    "editorHoverWidget.statusBarBackground": "#282a36",
    "editorHoverWidget.highlightForeground": "#9580ff",

    // Minimap
    "minimap.selectionHighlight": "#9580ffff",
    "minimap.findMatchHighlight": "#ffffa5ff",
    "minimap.errorHighlight": "#ff958080",
    "minimap.warningHighlight": "#ffca8080",
    "minimapSlider.background": "#9580ff30",
    "minimapSlider.hoverBackground": "#9580ff50",
    "minimapSlider.activeBackground": "#9580ff70",

    // Error Lens (used in Review mode)
    "errorLens.errorBackground": "#ff958005",
    "errorLens.errorForeground": "#ff95803b",
    "errorLens.warningBackground": "#ffca8005",
    "errorLens.warningForeground": "#ffca802e",
    "errorLens.infoBackground": "#92a2d405",
    "errorLens.infoForeground": "#92a2d488",
    "errorLens.hintBackground": "#8aff8005",
    "errorLens.hintForeground": "#8aff8088",
  },

  // ─────────────────────────────────────────────────────────
  // FONT & TYPOGRAPHY
  // ─────────────────────────────────────────────────────────
  "editor.fontFamily": "JetBrains Mono, monospace",
  "editor.fontSize": 13.5,
  // Alternates:
  // "editor.fontFamily": "DejaVu Sans Mono, monospace",
  // "editor.fontFamily": "Inter, monospace",
  // "editor.fontFamily": "Google Sans Code",
  // "editor.fontFamily": "Geist Mono, monospace",
  // "editor.fontFamily": "Maple Mono, monospace",
  // "editor.fontFamily": "Ubuntu Mono, monospace",
  // "editor.fontFamily": "Cascadia Code, monospace",
  // "editor.fontFamily": "Monaspace Neon, monospace",
  // "editor.fontFamily": "Monaspace Radon, monospace",
  // "editor.fontLigatures": "'calt', 'ss03'",
  // "editor.fontLigatures": true,
  // "editor.lineHeight": 1.6,

  // ─────────────────────────────────────────────────────────
  // EDITOR: APPEARANCE
  // ─────────────────────────────────────────────────────────
  "editor.lineNumbers": "relative",
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 200,
  "editor.renderWhitespace": "trailing",
  "editor.renderLineHighlight": "line",
  "editor.semanticHighlighting.enabled": true,
  "editor.occurrencesHighlight": "multiFile",
  "editor.roundedSelection": true,
  "editor.linkedEditing": true,
  "editor.guides.indentation": false,
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.bracketPairsHorizontal": false,
  "editor.definitionLinkOpensInPeek": false,
  "editor.unfoldOnCursorMove": false,
  "editor.stickyScroll.maxLineCount": 1,
  "editor.gotoLocation.multipleDefinitions": "goto",
  "diffEditor.renderSideBySide": true,
  "scm.diffDecorationsGutterVisibility": "always",

  // ─────────────────────────────────────────────────────────
  // EDITOR: CURSOR & SCROLL
  // ─────────────────────────────────────────────────────────
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorWidth": 1,
  "editor.cursorSurroundingLines": 8,
  "editor.smoothScrolling": true,
  "editor.fastScrollSensitivity": 15,
  "editor.scrollbar.horizontal": "auto",
  "editor.scrollbar.verticalScrollbarSize": 6,
  "editor.scrollbar.ignoreHorizontalScrollbarInContentHeight": true,
  "editor.overviewRulerBorder": true,
  "editor.hideCursorInOverviewRuler": false,

  // ─────────────────────────────────────────────────────────
  // EDITOR: INDENTATION
  // ─────────────────────────────────────────────────────────
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.indentSize": "tabSize",

  // ─────────────────────────────────────────────────────────
  // EDITOR: MINIMAP
  // ─────────────────────────────────────────────────────────
  "editor.minimap.renderCharacters": false,
  "editor.minimap.size": "fit",
  "editor.minimap.scale": 1,
  "editor.minimap.maxColumn": 80,
  "editor.minimap.showSlider": "always",

  // ─────────────────────────────────────────────────────────
  // EDITOR: HOVER & INLAY HINTS
  // ─────────────────────────────────────────────────────────
  "editor.hover.enabled": true,
  "editor.hover.delay": 10,
  "editor.hover.hidingDelay": 5000,
  "editor.hover.sticky": true,
  "editor.hover.above": false,
  "editor.inlayHints.enabled": "on",
  "debug.inlineValues": true,


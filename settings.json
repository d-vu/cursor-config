    "minimap.findMatchHighlight": "#ffffa5ff",
    "minimap.errorHighlight": "#ff958080",
    "minimap.warningHighlight": "#ffca8080",
    "minimapSlider.background": "#9580ff30",
    "minimapSlider.hoverBackground": "#9580ff50",
    "minimapSlider.activeBackground": "#9580ff70",
    "errorLens.errorBackground": "#ff958005",
    "errorLens.errorForeground": "#ff95803b",
    "errorLens.warningBackground": "#ffca8005",
    "errorLens.warningForeground": "#ffca802e",
    "errorLens.infoBackground": "#92a2d405",
    "errorLens.infoForeground": "#92a2d488",
    "errorLens.hintBackground": "#8aff8005",
    "errorLens.hintForeground": "#8aff8088",
    "[Dracula Theme Soft]": {
      "gitDecoration.deletedResourceForeground": "#ff5555",
      "gitDecoration.renamedResourceForeground": "#8be9fd",
      "gitDecoration.stageModifiedResourceForeground": "#ffb86c",
      "gitDecoration.stageDeletedResourceForeground": "#ff5555",
      "gitDecoration.conflictingResourceForeground": "#ff79c6",
      "gitDecoration.ignoredResourceForeground": "#6272a4",
      "gitDecoration.modifiedResourceForeground": "#c99862",
      "gitDecoration.untrackedResourceForeground": "#6fa876",
      "gitDecoration.addedResourceForeground": "#6fa876",
      "tab.activeModifiedBorder": "#c99862",
      "tab.inactiveModifiedBorder": "#6b5540",
      "tab.activeForeground": "#f8f8f2",
      "tab.inactiveForeground": "#8b93a7",
      "tab.activeBorderTop": "#bd93f9",
      "tab.activeBackground": "#2b2b3d",
      "tab.inactiveBackground": "#22222e",
      "tab.border": "#191a21",
      "tab.hoverBackground": "#2f2f42",
      "tab.hoverForeground": "#f8f8f2",
      "tree.indentGuidesStroke": "#4d5066",
      "tree.inactiveIndentGuidesStroke": "#33354a",
    },
  },
  // ═════════════════════════════════════════════════════════
  // FONT & TYPOGRAPHY
  // ═════════════════════════════════════════════════════════
  "editor.fontFamily": "JetBrains Mono, monospace",
  "editor.fontSize": 13.5,
  // Alternates:
  // "editor.fontFamily": "DejaVu Sans Mono, monospace",
  // "editor.fontFamily": "Inter, monospace",
  // "editor.fontFamily": "Google Sans Code",
  // "editor.fontFamily": "Geist Mono, monospace",
  // "editor.fontFamily": "Maple Mono, monospace",
  // "editor.fontFamily": "Ubuntu Mono, monospace",
  // "editor.fontFamily": "Cascadia Code, monospace",
  // "editor.fontFamily": "Monaspace Neon, monospace",
  // "editor.fontFamily": "Monaspace Radon, monospace",
  // "editor.fontLigatures": "'calt', 'ss03'",
  "editor.fontLigatures": true,
  // "editor.lineHeight": 1.6,
  // ═════════════════════════════════════════════════════════
  // EDITOR: APPEARANCE
  // ═════════════════════════════════════════════════════════
  "editor.lineNumbers": "relative",
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 200,
  "editor.renderWhitespace": "trailing",
  "editor.renderLineHighlight": "line",
  "editor.semanticHighlighting.enabled": true,
  "editor.occurrencesHighlight": "multiFile",
  "editor.roundedSelection": true,
  "editor.linkedEditing": true,
  "editor.guides.indentation": false,
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.bracketPairsHorizontal": false,
  "editor.definitionLinkOpensInPeek": false,
  "editor.unfoldOnCursorMove": false,
  "editor.stickyScroll.maxLineCount": 1,
  "editor.gotoLocation.multipleDefinitions": "goto",
  "diffEditor.renderSideBySide": true,
  "scm.diffDecorationsGutterVisibility": "always",
  // ═════════════════════════════════════════════════════════
  // EDITOR: CURSOR & SCROLL
  // ═════════════════════════════════════════════════════════
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorWidth": 1,
  "editor.cursorSurroundingLines": 15,
  "editor.cursorSurroundingLinesStyle": "all",
  "editor.smoothScrolling": true,
  "editor.fastScrollSensitivity": 15,
  "editor.scrollbar.horizontal": "auto",
  "editor.scrollbar.verticalScrollbarSize": 6,
  "editor.scrollbar.ignoreHorizontalScrollbarInContentHeight": true,
  "editor.overviewRulerBorder": true,
  "editor.hideCursorInOverviewRuler": false,
  // ═════════════════════════════════════════════════════════
  // EDITOR: INDENTATION
  // ═════════════════════════════════════════════════════════
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.indentSize": "tabSize",
  // ═════════════════════════════════════════════════════════
  // EDITOR: MINIMAP
  // ═════════════════════════════════════════════════════════
  "editor.minimap.renderCharacters": false,
  "editor.minimap.size": "fit",
  "editor.minimap.scale": 1,
  "editor.minimap.maxColumn": 80,
  "editor.minimap.showSlider": "always",
  // ═════════════════════════════════════════════════════════
  // EDITOR: HOVER & INLAY HINTS
  // ═════════════════════════════════════════════════════════
  "editor.hover.enabled": true,
  "editor.hover.delay": 500,
  "editor.hover.hidingDelay": 8000,
  "editor.hover.sticky": true,
  "editor.hover.above": false,
  "editor.inlayHints.enabled": "on",
  "debug.inlineValues": true,
  // ═════════════════════════════════════════════════════════
  // FORMATTING
  // ═════════════════════════════════════════════════════════
  "editor.formatOnSave": true,
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "prettier.bracketSameLine": true,
  // ═════════════════════════════════════════════════════════
  // TYPESCRIPT / JAVASCRIPT
  // ═════════════════════════════════════════════════════════
  "typescript.suggest.autoImports": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": true,
  // ═════════════════════════════════════════════════════════
  // TABS
  // ═════════════════════════════════════════════════════════
  "workbench.editor.wrapTabs": true,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.enablePreview": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.decorations.badges": true,
  "workbench.editor.tabActionCloseVisibility": false,
  "workbench.editor.labelFormat": "medium",
  "workbench.editor.splitSizing": "distribute",
  // ═════════════════════════════════════════════════════════
  // GIT & DIFF
  // ═════════════════════════════════════════════════════════
  "git.decorations.enabled": true,
  "git.openDiffOnClick": false,
  "problems.decorations.enabled": false,
  "workbench.editor.decorations.colors": true,
  // ═════════════════════════════════════════════════════════
  // EXPLORER & FILE TREE
  // ═════════════════════════════════════════════════════════
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "explorer.autoReveal": true,
  "explorer.openEditors.visible": 0,
  "explorer.decorations.badges": true,
  "explorer.decorations.colors": false,
  "explorer.sortOrder": "type",
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  // ═════════════════════════════════════════════════════════
  // FILE NESTING
  // ═════════════════════════════════════════════════════════
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.d.ts, ${capture}.test.ts",
    "*.tsx": "${capture}.test.tsx, ${capture}.stories.tsx",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, .npmrc",
    "tsconfig.json": "tsconfig.*.json",
    ".env": ".env.*, .envrc",
    "*.css": "${capture}.module.css",
  },
  // ═════════════════════════════════════════════════════════
  // BREADCRUMBS
  // ═════════════════════════════════════════════════════════
  "breadcrumbs.symbolPath": "on",
  "breadcrumbs.showFunctions": true,
  "breadcrumbs.showVariables": true,
  "breadcrumbs.showConstants": true,
  "breadcrumbs.showClasses": true,
  "breadcrumbs.showMethods": true,
  "breadcrumbs.showInterfaces": true,
  "breadcrumbs.showArrays": false,
  "breadcrumbs.showBooleans": false,
  "breadcrumbs.showEnums": false,
  "breadcrumbs.showEnumMembers": false,
  "breadcrumbs.showConstructors": false,
  "breadcrumbs.showFields": false,
  "breadcrumbs.showKeys": false,
  "breadcrumbs.showNull": false,
  "breadcrumbs.showNumbers": false,
  "breadcrumbs.showObjects": false,
  "breadcrumbs.showStrings": false,
  "breadcrumbs.showStructs": false,
  "breadcrumbs.showTypeParameters": false,
  "breadcrumbs.showEvents": false,
  "breadcrumbs.showOperators": false,
  "breadcrumbs.showPackages": false,
  "breadcrumbs.showModules": false,
  "breadcrumbs.showNamespaces": false,
  // ═════════════════════════════════════════════════════════
  // OUTLINE
  // ═════════════════════════════════════════════════════════
  "outline.icons": true,
  "outline.problems.enabled": false,
  "outline.collapseItems": "alwaysCollapse",
  "outline.showVariables": false,
  // ═════════════════════════════════════════════════════════
  // SEARCH
  // ═════════════════════════════════════════════════════════
  "search.showLineNumbers": true,
  "search.smartCase": true,
  "search.seedWithNearestWord": true,
  // ═════════════════════════════════════════════════════════
  // TERMINAL
  // ═════════════════════════════════════════════════════════
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorWidth": 1,
  "terminal.integrated.mouseWheelZoom": true,
  "terminal.integrated.defaultLocation": "editor",
  // ═════════════════════════════════════════════════════════
  // WORKBENCH & WINDOW
  // ═════════════════════════════════════════════════════════
  "workbench.sideBar.location": "right",
  "workbench.list.smoothScrolling": true,
  "workbench.reduceMotion": "on",
  "workbench.enableExperiments": false,

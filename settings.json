{
  // ═════════════════════════════════════════════════════════
  // MODE TOGGLE — flip comments to switch
  // ═════════════════════════════════════════════════════════
  // ── CODING MODE (quiet: no lint, no error lines) ──
  // "typescript.validate.enable": false,
  // "javascript.validate.enable": false,
  // "editor.renderValidationDecorations": "off",
  // "errorLens.enabled": false,
  // "eslint.enable": false,
  // "editor.showUnused": false,
  // "editor.showDeprecated": false,
  // ── REVIEW MODE (full diagnostics) ──
  "typescript.validate.enable": true,
  "javascript.validate.enable": true,
  "editor.renderValidationDecorations": "on",
  "errorLens.enabled": true,
  "problems.decorations.enabled": true,
  // ═════════════════════════════════════════════════════════
  // THEME & ICONS
  // ═════════════════════════════════════════════════════════
  "workbench.colorTheme": "Dracula Theme Soft",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.iconTheme": "simple-icons",
  // ═════════════════════════════════════════════════════════
  // SEMANTIC TOKEN COLORS (TypeScript — wins over TextMate)
  // ═════════════════════════════════════════════════════════
  "editor.semanticTokenColorCustomizations": {
    "[Dracula Theme Soft]": {
      "rules": {
        // ── Functions / methods / classes ──
        "function": { "foreground": "#62e884" },
        "method": { "foreground": "#62e884" },
        "function.defaultLibrary": { "foreground": "#62e884" },
        "method.defaultLibrary": { "foreground": "#62e884" },
        "class.defaultLibrary": { "foreground": "#62e884", "italic": false },
        // ── Variable declarations ──
        "variable.declaration": { "foreground": "#bd93f9" },
        "variable.declaration.local": { "foreground": "#bd93f9" },
        "variable.declaration.readonly": { "foreground": "#bd93f9" },
        "variable.declaration.readonly.local": { "foreground": "#bd93f9" },
        // ── Variable usages (base intentionally omitted) ──
        "variable.readonly": { "foreground": "#b3d4ff" },
        "variable.local": { "foreground": "#b3d4ff" },
        "variable.readonly.local": { "foreground": "#b3d4ff" },
        // ── Declared properties ──
        "property.declaration": { "foreground": "#8fe0d0" },
        "property.declaration.readonly": { "foreground": "#8fe0d0" },
        "property": { "foreground": "#8fe0d0" },
        "property.readonly": { "foreground": "#8fe0d0" },
        "property.defaultLibrary": { "foreground": "#8fe0d0" },
        "property.defaultLibrary.readonly": { "foreground": "#8fe0d0" },
        // ── Types / interfaces / enums ──
        "type": { "foreground": "#e0b088", "bold": true },
        "typeParameter": { "foreground": "#e0b088", "bold": true },
        "enum": { "foreground": "#e0b088", "bold": true },
        "interface": { "foreground": "#e0b088", "italic": false, "bold": true },
        "interface.defaultLibrary": {
          "foreground": "#e0b088",
          "bold": true,
          "italic": false,
        },
        // ── Import aliases ──
        "variable.other.readwrite.alias": { "foreground": "#bd93f9" },
      },
    },
  },
  // ═════════════════════════════════════════════════════════
  // TEXTMATE TOKEN COLORS (fallback when semantic doesn't apply)
  // Ordered to mirror the semantic roles above. Keep these in sync
  // with the semantic hexes to avoid flicker on scroll.
  // ═════════════════════════════════════════════════════════
  "editor.tokenColorCustomizations": {
    "[Dracula Theme Soft]": {
      "textMateRules": [
        // ── Functions / built-in classes ──
        {
          "scope": [
            "support.function",
            "entity.name.function",
            "support.class.builtin",
          ],
          "settings": { "foreground": "#62e884" },
        },
        {
          "scope": ["entity.name.type.class"],
          "settings": { "foreground": "#62e884", "fontStyle": "bold" },
        },
        // ── Variable usages ──
        {
          "scope": [
            "variable.other.readwrite",
            "variable.other.constant.object",
          ],
          "settings": { "foreground": "#b3d4ff" },
        },
        // ── Object property access (matches semantic salmon) ──

        // ── Properties (incl. object-literal keys, to kill scroll flicker) ──
        {
          "scope": [
            "variable.other.property",
            "variable.other.object.property",
            "support.constant.property",
            "support.variable.property",
            "meta.object-literal.key",
            "support.type.property-name",
          ],
          "settings": { "foreground": "#8fe0d0" },
        },
        // ── Parameters (reserved white) ──
        {
          "scope": ["variable.parameter"],
          "settings": { "foreground": "#e6e3e3" },
        },
        // ── Built-in vars (this, super) ──
        {
          "scope": ["variable.language.this.ts", "meta.object.member"],
          "settings": { "foreground": "#e668af" },
        },
        // ── Types / primitives ──
        {
          "scope": ["support.type.primitive", "support.type.builtin"],
          "settings": { "foreground": "#d4b89c" },
        },
        // ── Booleans truthy ──
        {
          "scope": [
            "constant.language.boolean.true.ts",
            "constant.language.boolean.true",
            "constant.language.json.comments",
          ],
          "settings": { "foreground": "#d0e498" },
        },
        // ── Booleans falsy + null + undefined ──
        {
          "scope": [
            "constant.language.boolean.false.ts",
            "constant.language.boolean.false",
            "constant.language.null.ts",
            "constant.language.undefined.ts",
          ],
          "settings": { "foreground": "#aec072" },
        },
        // ── Control flow / async ──
        {
          "scope": [
            "storage.modifier.async",
            "keyword.control.trycatch",
            "keyword.control.conditional",
            "keyword.control.loop",
            "keyword.control.flow",
          ],
          "settings": { "foreground": "#ffb86c" },
        },
        // ── Operators ──
        {
          "scope": [
            "keyword.operator.logical",
            "keyword.operator.comparison",
            "keyword.operator.relational",
          ],
          "settings": { "foreground": "#f8c5ff", "fontStyle": "bold" },
        },
        // ── Strings ──
        {
          "scope": "string",
          "settings": { "foreground": "#ddd683" },
        },
        // ── Numbers ──
        {
          "scope": ["constant.numeric.decimal", "constant.numeric"],
          "settings": { "foreground": "#dcdf53" },
        },
        // ── JSX prop names ──
        {
          "scope": [
            "entity.other.attribute-name.tsx",
            "entity.other.attribute-name.jsx",
          ],
          "settings": { "foreground": "#7fc9a8" },
        },
        // ── JSX child text ──
        {
          "scope": [
            "meta.jsx.children.tsx",
            "meta.jsx.children.js",
            // "meta.embedded.block",
          ],
          // "settings": { "foreground": "#b2b2d0" },
          "settings": { "foreground": "#c5c5d8" },
        },
        // ── React components (capitalized) → coral ──
        {
          "scope": ["support.class.component", "support.class.component.tsx"],
          "settings": { "foreground": "#ff9580" },
        },

        // ── Comments ──
        {
          "scope": ["comment", "punctuation.definition.comment"],
          "settings": { "foreground": "#9988bb", "fontStyle": "" },
        },
        // ── Strip italics (no color change) ──
        {
          "scope": [
            "variable.parameter",
            "entity.name.type",
            "support.type.primitive",
            "support.type.builtin",
            "meta.type.annotation.ts",
            "support.class.component.tsx",
            "entity.other.attribute-name.tsx",
            "variable.language.this",
          ],
          "settings": { "fontStyle": "" },
        },
      ],
    },
  },
  // ═════════════════════════════════════════════════════════
  // WORKBENCH COLOR CUSTOMIZATIONS (UI chrome)
